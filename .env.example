# Telegram Bot — para receber notificações de promoções novas.
# Como obter:
#   1) Fale com @BotFather no Telegram, /newbot, copie o TOKEN.
#   2) Mande qualquer mensagem ao seu bot e abra:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      Procure "chat":{"id": ...} — esse número é o CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (Recomendado no servidor) Segurança do webhook em produção.
#   WEBHOOK_ADMIN_TOKEN — protege GET /setup-webhook e /status (403 se ausente).
#                         O servidor também aceita o nome legado ADMIN_TOKEN.
#   TELEGRAM_WEBHOOK_SECRET — enviado ao Telegram no setWebhook e validado no
#                             header X-Telegram-Bot-Api-Secret-Token em /webhook.
#   TELEGRAM_ALLOWED_CHAT_IDS — lista de chats autorizados (vírgula). Se vazio,
#                               usa TELEGRAM_CHAT_ID.
WEBHOOK_ADMIN_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=

# (Opcional) Resumo de alta carga no Telegram. Quando um run/alert detecta
# muitas mudanças, em vez de mandar um bloco detalhado por produto, manda um
# resumo: uma linha por item, agrupado por tipo de peça (tênis, vestuário,
# acessórios, agasalhos, camisas de time, outros). O digest da noite sempre usa
# o resumo.
#   SUMMARY_THRESHOLD — nº de mudanças a partir do qual o alert vira resumo (default 15)
#   SUMMARY_PER_GROUP — máx. de itens listados por grupo antes do "…+K mais" (default 12)
SUMMARY_THRESHOLD=15
SUMMARY_PER_GROUP=12

# (Opcional) Proxy só para o scraper da Centauro, que costuma ser bloqueado
# pelo Akamai em IPs residenciais. Aceita http://, https:// ou socks5://.
# Exemplos:
#   CENTAURO_PROXY=socks5://127.0.0.1:1080
#   CENTAURO_PROXY=http://user:pass@proxy.example.com:8080
# Se vazio, o scraper tenta direto (e ignora a fonte se tomar 403).
CENTAURO_PROXY=

# (Opcional) Caminho do banco de dados SQLite.
# Default: <repo>/data/prices.db (calculado automaticamente).
# No Docker, defina como /app/data/prices.db.
# DB_PATH=
